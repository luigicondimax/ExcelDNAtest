<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ExcelDNAtest.FormImpostazioniExcelToolset"
        Title="Excel Toolset - Impostazioni"
        Width="480" Height="320"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="True"
        CanResize="false">

    <Grid RowDefinitions="*, Auto" Margin="15">
        
        <TabControl Grid.Row="0">
            
            <TabItem Name="TabGenerali">
                <StackPanel Margin="10" Spacing="12">
                    <TextBlock Name="LabelLingua" VerticalAlignment="Center" />
                    <ComboBox Name="ComboBoxLingua" HorizontalAlignment="Stretch" />
                </StackPanel>
            </TabItem>
                        
        </TabControl>
        
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10" 
                    Margin="0,15,0,0">
            
            <Button Name="ButtonSalva" Click="ButtonSalva_Click" HotKey="Enter" />
            <Button Name="ButtonAnnulla" Click="ButtonAnnulla_Click" HotKey="Escape" />
        </StackPanel>
    </Grid>
</Window>